{
  "name": "secure-ephemeral-content-viewer",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm --prefix packages/shared run build",
    "dev": "concurrently \"npm run dev -w @secure-viewer/api\" \"npm run dev -w @secure-viewer/web\"",
    "dev:api": "npm run dev -w @secure-viewer/api",
    "dev:web": "npm run dev -w @secure-viewer/web",
    "build:shared": "npm --prefix packages/shared run build",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web run build",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "test": "npm run test -w @secure-viewer/shared && npm run test -w @secure-viewer/api && npm run test -w @secure-viewer/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
